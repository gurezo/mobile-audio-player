# Specifies intentionally untracked files to ignore when using Git
# http://git-scm.com/docs/gitignore

# Editor/OS noise
*~
*.sw[mnpcod]
*.log
*.tmp
*.tmp.*
log.txt
*.sublime-project
*.sublime-workspace
.vscode/
.idea/
.DS_Store
Thumbs.db
UserInterfaceState.xcuserstate

# Angular / Node build output
/dist
/tmp
/out-tsc
/bazel-out

# Node
/node_modules
npm-debug.log
yarn-error.log

# Angular CLI cache
/.angular/cache

# Legacy Ionic/Cordova artifacts
.sass-cache/
.tmp/
.versions/
.sourcemaps/
coverage/
tmp/
temp/
hooks/
platforms/
plugins/
plugins/android.json
plugins/ios.json
www/
$RECYCLE.BIN/
